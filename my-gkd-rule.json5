{
  // 规则基础信息
  id: 20260329001,
  name: '自用规则',
  version: 2026032901,
  author: '自用优化版',
  checkUpdateUrl: '',
  supportUri: '',

  // 规则分类（细化分类，按需开关，默认仅开启前4类安全规则）
  categories: [
    {
      key: 0,
      name: '开屏广告',
      desc: '关闭APP启动时的开屏广告、跳过倒计时',
      order: -10,
      fastQuery: true,
      matchTime: 10000,
      actionMaximum: 2,
      resetMatch: 'app',
      forcedTime: 10000,
      actionCdKey: 0,
      actionMaximumKey: 0,
      priorityTime: 10000,
      disableIfAppGroupMatch: '开屏广告',
    },
    {
      key: 1,
      name: '全屏弹窗广告',
      desc: '应用内弹出的全屏广告、活动弹窗',
      order: -9,
      fastQuery: true,
      matchTime: 10000,
      actionMaximum: 1,
      resetMatch: 'activity',
    },
    {
      key: 2,
      name: '高频骚扰弹窗',
      desc: '青少年模式、更新提示、个性化推荐等非广告类骚扰弹窗',
      order: -8,
      fastQuery: true,
      matchTime: 10000,
      actionMaximum: 1,
      resetMatch: 'activity',
    },
    {
      key: 3,
      name: '权限索要弹窗',
      desc: '非必要权限索要弹窗（默认关闭，按需开启）',
      order: -7,
      fastQuery: true,
      enable: false,
    },
    {
      key: 4,
      name: '信息流卡片广告',
      desc: '首页、内容流中的嵌入广告卡片（默认关闭，按需开启）',
      order: -6,
      fastQuery: true,
      enable: false,
    },
    {
      key: 5,
      name: '评论区广告',
      desc: '评论区嵌入的广告卡片（默认关闭，按需开启）',
      order: -5,
      fastQuery: true,
      enable: false,
    },
    {
      key: 6,
      name: '视频贴片广告',
      desc: '视频播放前后的贴片广告（默认关闭，按需开启）',
      order: -4,
      fastQuery: true,
      enable: false,
    },
    {
      key: 7,
      name: '功能类自动操作',
      desc: '自动签到、关闭弹窗等辅助功能（默认关闭，按需开启，有极低误触风险）',
      order: 0,
      enable: false,
    },
  ],

  // 全局通用规则（全APP生效，已做系统应用排除，误触率极低）
  globalGroups: [
    // 全局开屏广告通用规则（奥怪兜底逻辑+甘霖优化，误触率天花板）
    {
      key: 100,
      name: '全局开屏广告-跳过按钮通用规则',
      desc: '适配90%以上APP的开屏跳过，已做严格匹配限制',
      category: 0,
      fastQuery: true,
      matchTime: 10000,
      actionMaximum: 2,
      resetMatch: 'app',
      priorityTime: 10000,
      // 排除系统应用、桌面、输入法，彻底避免误触系统功能
      excludeIds: [
        'com.android.systemui',
        'com.android.launcher3',
        'com.google.android.apps.nexuslauncher',
        'com.android.dialer',
        'com.android.contacts',
        'com.android.mms',
        'com.android.settings',
        'com.android.inputmethod.latin',
        'com.tencent.qqpinyin',
        'com.baidu.input',
        'com.sohu.inputmethod.sogou',
        'com.google.android.inputmethod.latin',
      ],
      rules: [
        {
          fastQuery: true,
          matches: '[text^="跳过" || text^="跳过广告" || text^="跳過" || text^="Skip" || text^="skip"][text.length<=10][clickable=true][visibleToUser=true]',
        },
        {
          fastQuery: true,
          matches: '[desc^="跳过" || desc^="跳过广告" || desc^="跳過"][desc.length<=10][clickable=true][visibleToUser=true]',
        },
        {
          fastQuery: true,
          matches: '[id*="skip" || id*="jump"][id!*="input"][id!*="edit"][clickable=true][visibleToUser=true]',
        },
      ],
    },
    // 全局开屏广告-倒计时结束自动关闭
    {
      key: 101,
      name: '全局开屏广告-倒计时自动关闭',
      desc: '无跳过按钮，倒计时结束自动消失的开屏广告',
      category: 0,
      fastQuery: true,
      matchTime: 10000,
      actionMaximum: 1,
      resetMatch: 'app',
      excludeIds: [
        'com.android.systemui',
        'com.android.launcher3',
        'com.android.dialer',
        'com.android.settings',
        'com.baidu.input',
        'com.sohu.inputmethod.sogou',
      ],
      rules: [
        {
          fastQuery: true,
          matches: '[text*="广告" && (text*="s" || text*="秒")][text.length<=10][visibleToUser=true] << [clickable=true][visibleToUser=true]',
          action: 'click',
        },
      ],
    },
    // 全局弹窗广告-关闭按钮通用规则
    {
      key: 102,
      name: '全局弹窗广告-关闭按钮通用规则',
      desc: '适配绝大多数APP的全屏弹窗广告关闭',
      category: 1,
      fastQuery: true,
      matchTime: 10000,
      actionMaximum: 1,
      resetMatch: 'activity',
      rules: [
        {
          fastQuery: true,
          matches: '[text="关闭" || text="關閉" || text="×" || text="✕" || text="❌" || text="取消"][text.length<=4][clickable=true][visibleToUser=true]',
        },
        {
          fastQuery: true,
          matches: '[desc="关闭" || desc="關閉" || desc="取消"][desc.length<=4][clickable=true][visibleToUser=true]',
        },
        {
          fastQuery: true,
          matches: '[id*="close" || id*="dismiss" || id*="cancel"][id!*="input"][id!*="edit"][clickable=true][visibleToUser=true]',
        },
      ],
    },
    // 高频骚扰弹窗通用规则（青少年模式、更新提示等）
    {
      key: 103,
      name: '青少年模式弹窗通用关闭规则',
      desc: '自动关闭APP启动时弹出的青少年模式/未成年人模式弹窗',
      category: 2,
      fastQuery: true,
      matchTime: 10000,
      actionMaximum: 1,
      resetMatch: 'activity',
      rules: [
        {
          fastQuery: true,
          matches: '[text*="青少年模式" || text*="未成年人模式"] + [text="我知道了" || text="关闭" || text="取消"][clickable=true][visibleToUser=true]',
        },
        {
          fastQuery: true,
          matches: '[text*="青少年模式" || text*="未成年人模式"] << [id*="close" || id*="cancel"][clickable=true][visibleToUser=true]',
        },
      ],
    },
    {
      key: 104,
      name: 'APP更新提示弹窗通用关闭规则',
      desc: '自动关闭APP强制弹出的版本更新提示弹窗',
      category: 2,
      fastQuery: true,
      matchTime: 10000,
      actionMaximum: 1,
      resetMatch: 'activity',
      rules: [
        {
          fastQuery: true,
          matches: '[text*="版本更新" || text*="立即更新"] + [text="取消" || text="稍后再说" || text="暂不更新"][clickable=true][visibleToUser=true]',
        },
        {
          fastQuery: true,
          matches: '[text*="发现新版本"] << [text="取消" || text="关闭"][clickable=true][visibleToUser=true]',
        },
      ],
    },
    {
      key: 105,
      name: '个性化推荐弹窗通用关闭规则',
      desc: '自动关闭APP弹出的个性化推荐/隐私政策弹窗',
      category: 2,
      fastQuery: true,
      matchTime: 10000,
      actionMaximum: 1,
      resetMatch: 'activity',
      rules: [
        {
          fastQuery: true,
          matches: '[text*="个性化推荐" || text*="个性化广告"] + [text="关闭" || text="拒绝" || text="不同意"][clickable=true][visibleToUser=true]',
        },
        {
          fastQuery: true,
          matches: '[text*="隐私政策" || text*="用户协议"] << [text="我知道了" || text="同意"][clickable=true][visibleToUser=true]',
        },
      ],
    },
  ],

